# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
Jumper/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
Jumper/[Aa]ssets/[Ss]treamingAssets/aa.meta
Jumper/[Aa]ssets/[Ss]treamingAssets/aa/*

# ============================
# ML-Agents training results
# ============================
Jumper/results/
results/

# Python virtual env
venv/
env/
*_env/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# ============================
